{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar Fortran",
            "type": "shell",
            "command": "gfortran",
            "args": [
                "-g",
                "-Wall",
                "-std=f2008",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Ejecutar Fortran",
            "type": "shell",
            "command": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "dependsOn": "Compilar Fortran",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
